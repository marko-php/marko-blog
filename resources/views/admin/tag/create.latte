{layout 'admin-panel::layout/base'}

{default $pageTitle = 'Create Tag', $errors = [], $input = []}

{block content}
    <h1>Create Tag</h1>

    <ul n:if="$errors" class="error-list" role="alert">
        {foreach $errors as $error}
            <li>{$error}</li>
        {/foreach}
    </ul>

    <form method="post" action="/admin/blog/tags" class="admin-form">
        <div class="form-group">
            <label for="tag-name">Name</label>
            <input type="text" id="tag-name" name="name" value="{$input['name'] ?? ''}" required>
        </div>

        <div class="form-actions">
            <button type="submit" class="btn btn-primary">Create Tag</button>
            <a href="/admin/blog/tags" class="btn btn-secondary">Cancel</a>
        </div>
    </form>
{/block}
