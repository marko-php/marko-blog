{
    "name": "marko/blog",
    "description": "Blog module for Marko Framework",
    "type": "library",
    "license": "MIT",
    "version": "1.0.0",
    "repositories": [
        {
            "type": "path",
            "url": "../core"
        },
        {
            "type": "path",
            "url": "../routing"
        },
        {
            "type": "path",
            "url": "../database"
        },
        {
            "type": "path",
            "url": "../view"
        }
    ],
    "require": {
        "php": "^8.5",
        "marko/core": "@dev",
        "marko/routing": "@dev",
        "marko/database": "@dev",
        "marko/view": "@dev"
    },
    "require-dev": {
        "pestphp/pest": "^4.0"
    },
    "autoload": {
        "psr-4": {
            "Marko\\Blog\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Marko\\Blog\\Tests\\": "tests/"
        }
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    }
}
