{
    "name": "marko/blog",
    "description": "Blog module for Marko Framework",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.5",
        "marko/core": "self.version",
        "marko/routing": "self.version",
        "marko/database": "self.version",
        "marko/view": "self.version",
        "marko/cache": "self.version",
        "marko/mail": "self.version",
        "marko/config": "self.version",
        "marko/session": "self.version"
    },
    "suggest": {
        "marko/admin": "Admin panel integration for managing blog content",
        "marko/admin-auth": "Admin authentication for blog admin controllers",
        "marko/view-latte": "Latte template engine for default blog templates",
        "marko/mail-log": "Log-based mail driver for development and debugging",
        "marko/mail-smtp": "SMTP mail driver for production email sending"
    },
    "require-dev": {
        "pestphp/pest": "^4.0",
        "marko/testing": "self.version"
    },
    "autoload": {
        "psr-4": {
            "Marko\\Blog\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Marko\\Blog\\Tests\\": "tests/"
        }
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "extra": {
        "marko": {
            "module": true
        }
    }
}
