{
    "name": "marko/blog",
    "description": "Blog module for Marko Framework",
    "type": "library",
    "license": "MIT",
    "version": "1.0.0",
    "repositories": [
        {
            "type": "path",
            "url": "../core"
        },
        {
            "type": "path",
            "url": "../routing"
        },
        {
            "type": "path",
            "url": "../database"
        },
        {
            "type": "path",
            "url": "../view"
        },
        {
            "type": "path",
            "url": "../cache"
        },
        {
            "type": "path",
            "url": "../mail"
        },
        {
            "type": "path",
            "url": "../config"
        },
        {
            "type": "path",
            "url": "../session"
        }
    ],
    "require": {
        "php": "^8.5",
        "marko/core": "@dev",
        "marko/routing": "@dev",
        "marko/database": "@dev",
        "marko/view": "@dev",
        "marko/cache": "@dev",
        "marko/mail": "@dev",
        "marko/config": "@dev",
        "marko/session": "@dev"
    },
    "suggest": {
        "marko/admin": "Admin panel integration for managing blog content",
        "marko/admin-auth": "Admin authentication for blog admin controllers",
        "marko/view-latte": "Latte template engine for default blog templates",
        "marko/mail-log": "Log-based mail driver for development and debugging",
        "marko/mail-smtp": "SMTP mail driver for production email sending"
    },
    "require-dev": {
        "pestphp/pest": "^4.0"
    },
    "autoload": {
        "psr-4": {
            "Marko\\Blog\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Marko\\Blog\\Tests\\": "tests/"
        }
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "extra": {
        "marko": {
            "module": true
        }
    }
}
